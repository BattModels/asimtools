[MASTER]
ignore=CVS,.git,__pycache__
persistent=yes
load-plugins=

[MESSAGES CONTROL]
disable=
    R0801,   # Similar lines in N files
    W0511,   # TODO/FIXME notes

[REPORTS]
output-format=colorized
reports=no
score=yes

[FORMAT]
max-line-length=100
max-module-lines=1500
indent-string='    '
indent-after-paren=4

[BASIC]
# Module names: lowercase with underscores
module-rgx=[a-z_][a-z0-9_]*$

# Constants: ALL_CAPS or TypeVar-style (e.g. Atoms = TypeVar('Atoms'))
const-rgx=(([A-Z_][A-Z0-9_]*)|([A-Z][a-zA-Z0-9]+)|(__.*__))$

# Classes: PascalCase
class-rgx=[A-Z][a-zA-Z0-9]+$

# Functions and methods: snake_case, up to 40 chars
function-rgx=[a-z_][a-z0-9_]{1,40}$
method-rgx=(_?[a-z_][a-z0-9_]{1,40}|__[a-z]+__)$

# Attributes, arguments, variables: snake_case
attr-rgx=[a-z_][a-z0-9_]{1,40}$
argument-rgx=[a-z_][a-z0-9_]{1,40}$
variable-rgx=[a-z_][a-z0-9_]{1,40}$

# Short names allowed in loops and comprehensions
good-names=i,j,k,v,ex,Run,_,f,n,x,y,z

no-docstring-rgx=^_(?!_)

[DESIGN]
max-args=8
max-locals=20
max-returns=8
max-branches=15
max-statements=60
max-parents=7
max-attributes=15
min-public-methods=1
max-public-methods=30

[VARIABLES]
init-import=no
dummy-variables-rgx=_+$|(_[a-zA-Z0-9_]*[a-zA-Z0-9]+$)|dummy|^ignored_|^unused_

[TYPECHECK]
ignore-mixin-members=yes
ignored-classes=

[SIMILARITIES]
min-similarity-lines=6
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes

[MISCELLANEOUS]
notes=FIXME,XXX,TODO

[IMPORTS]
allow-reexport-from-package=yes
